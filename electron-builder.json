{
  "appId": "com.smartcam.monitor",
  "productName": "SmartCam Monitor",
  "directories": {
    "output": "dist-package"
  },
  "files": [
    "dist/**/*",
    "package.json"
  ],
  "asar": true,
  "asarUnpack": [
    "**/node_modules/onnxruntime-node/**/*"
  ],
  "extraResources": [
    {
      "from": "node_modules/ffmpeg-static/ffmpeg.exe",
      "to": "bin/ffmpeg.exe"
    },
    {
      "from": "ai-engine/dist/camera_trainer.exe",
      "to": "ai-engine/camera_trainer.exe",
      "filter": [
        "**/*"
      ]
    },
    {
      "from": "ai-engine/dist/dataset_trainer.exe",
      "to": "ai-engine/dataset_trainer.exe",
      "filter": [
        "**/*"
      ]
    },
    {
      "from": "ai-engine/datasets",
      "to": "ai-engine/datasets",
      "filter": [
        "**/*"
      ]
    },
    {
      "from": "ai-engine/weights",
      "to": "ai-engine/weights",
      "filter": [
        "**/*"
      ]
    }
  ],
  "win": {
    "icon": "build/icon.ico"
  },
  "mac": {
    "icon": "build/icon.icns"
  },
  "linux": {
    "icon": "build/icons"
  }
}